{
  "name": "ibm-bob-tracker",
  "version": "2.0.0",
  "description": "IBM Bob News Tracker — React/TypeScript/Node",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,server -c cyan,yellow \"vite\" \"tsx watch src/server/index.ts\"",
    "build": "vite build",
    "start": "node --import tsx/esm src/server/index.ts",
    "fetch": "tsx src/server/worker/index.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^4.21.2",
    "fast-xml-parser": "^4.5.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.1"
  }
}
